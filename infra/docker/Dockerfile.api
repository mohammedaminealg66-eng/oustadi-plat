FROM node:22-alpine
RUN apk add --no-cache python3 make g++
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate
COPY . .
RUN pnpm install
RUN cd apps/api && pnpm exec prisma generate
RUN pnpm --filter @oustadi/api run build
EXPOSE 3000
RUN printf '#!/bin/sh\nset -e\ncd apps/api && pnpm exec prisma db push --accept-data-loss && node prisma/init.js && exec node dist/main.js\n' > /entrypoint.sh && chmod +x /entrypoint.sh
CMD ["/entrypoint.sh"]
